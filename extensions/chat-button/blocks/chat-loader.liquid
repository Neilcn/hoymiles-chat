<script>
(function () {
  function findTriggerFromEvent(e) {
    if (!e) return null;

    if (typeof e.composedPath === 'function') {
      const path = e.composedPath();
      for (let i = 0; i < path.length; i++) {
        const node = path[i];
        if (node && node.nodeType === 1 && node.classList && node.classList.contains('open-chat-window')) {
          return node;
        }
      }
    }

    if (e.target && typeof e.target.closest === 'function') {
      return e.target.closest('.open-chat-window');
    }

    return null;
  }

  function detectStoreLocale() {
    const langAttr = document.documentElement && document.documentElement.lang;
    if (langAttr) return langAttr;

    const pathMatch = window.location.pathname.match(/^\/([a-z]{2}(?:-[A-Z]{2})?)(?:\/|$)/);
    if (pathMatch && pathMatch[1]) return pathMatch[1];

    return 'en';
  }

  function initChat() {
    if (document.body.dataset.chatDelegateBound) return;

    document.body.dataset.chatDelegateBound = 'true';

    document.body.addEventListener('click', async function (e) {
      const trigger = findTriggerFromEvent(e);
      if (!trigger) return;

      e.preventDefault();

      // Open a proxy URL immediately; backend resolves and redirects to chat URL.
      const locale = encodeURIComponent(detectStoreLocale());
      window.open('/apps/chat?redirect=1&locale=' + locale, '_blank');
    }, true);

  }

  document.addEventListener('DOMContentLoaded', initChat);

  // fallback for Shopify themes (important)
  setInterval(initChat, 1000);

})();
</script>

