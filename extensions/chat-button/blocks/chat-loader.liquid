<script>
(function () {
  function ensureStyle() {
    if (document.getElementById('hoymiles-chat-style')) return;

    const style = document.createElement('style');
    style.id = 'hoymiles-chat-style';
    style.textContent = [
      '.hoymiles-chat-overlay {',
      '  position: fixed;',
      '  inset: 0;',
      '  background: rgba(0, 0, 0, 0.35);',
      '  z-index: 9998;',
      '  opacity: 0;',
      '  pointer-events: none;',
      '  transition: opacity 160ms ease;',
      '}',
      '.hoymiles-chat-overlay.is-open {',
      '  opacity: 1;',
      '  pointer-events: auto;',
      '}',
      '.hoymiles-chat-panel {',
      '  position: fixed;',
      '  right: 24px;',
      '  bottom: 24px;',
      '  width: 400px;',
      '  height: 600px;',
      '  max-width: calc(100vw - 24px);',
      '  max-height: calc(100vh - 24px);',
      '  border: 0;',
      '  border-radius: 16px;',
      '  background: #fff;',
      '  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);',
      '  z-index: 9999;',
      '  display: none;',
      '  overflow: hidden;',
      '}',
      '.hoymiles-chat-panel.is-open {',
      '  display: block;',
      '}',
      '.hoymiles-chat-close {',
      '  position: absolute;',
      '  top: 10px;',
      '  right: 10px;',
      '  width: 28px;',
      '  height: 28px;',
      '  border: 0;',
      '  border-radius: 999px;',
      '  background: rgba(0, 0, 0, 0.08);',
      '  color: #111;',
      '  cursor: pointer;',
      '  z-index: 2;',
      '}',
      '.hoymiles-chat-frame {',
      '  width: 100%;',
      '  height: 100%;',
      '  border: 0;',
      '}',
      '@media (max-width: 768px) {',
      '  .hoymiles-chat-panel {',
      '    left: 12px;',
      '    right: 12px;',
      '    bottom: 12px;',
      '    width: auto;',
      '    height: min(78vh, 600px);',
      '    max-width: none;',
      '    border-radius: 14px;',
      '  }',
      '}'
    ].join('\n');

    document.head.appendChild(style);
  }

  function getOrCreateContainer() {
    let root = document.getElementById('hoymiles-chat-root');
    if (root) return root;

    root = document.createElement('div');
    root.id = 'hoymiles-chat-root';

    const overlay = document.createElement('div');
    overlay.className = 'hoymiles-chat-overlay';

    const panel = document.createElement('div');
    panel.className = 'hoymiles-chat-panel';

    const close = document.createElement('button');
    close.className = 'hoymiles-chat-close';
    close.type = 'button';
    close.setAttribute('aria-label', 'Close chat');
    close.textContent = 'x';

    const frame = document.createElement('iframe');
    frame.className = 'hoymiles-chat-frame';
    frame.loading = 'lazy';
    frame.title = 'Chat';
    frame.allow = 'clipboard-read; clipboard-write';

    panel.appendChild(close);
    panel.appendChild(frame);
    root.appendChild(overlay);
    root.appendChild(panel);
    document.body.appendChild(root);

    function closeChat() {
      overlay.classList.remove('is-open');
      panel.classList.remove('is-open');
    }

    overlay.addEventListener('click', closeChat);
    close.addEventListener('click', closeChat);

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        closeChat();
      }
    });

    return root;
  }

  function openChat(url) {
    const root = getOrCreateContainer();
    const overlay = root.querySelector('.hoymiles-chat-overlay');
    const panel = root.querySelector('.hoymiles-chat-panel');
    const frame = root.querySelector('.hoymiles-chat-frame');

    if (!frame || !overlay || !panel) return;

    if (frame.src !== url) {
      frame.src = url;
    }

    overlay.classList.add('is-open');
    panel.classList.add('is-open');
  }

  function findTriggerFromEvent(e) {
    if (!e) return null;

    if (typeof e.composedPath === 'function') {
      const path = e.composedPath();
      for (let i = 0; i < path.length; i++) {
        const node = path[i];
        if (node && node.nodeType === 1 && node.classList && node.classList.contains('open-chat-window')) {
          return node;
        }
      }
    }

    if (e.target && typeof e.target.closest === 'function') {
      return e.target.closest('.open-chat-window');
    }

    return null;
  }

  function detectStoreLocale() {
    const langAttr = document.documentElement && document.documentElement.lang;
    if (langAttr) return langAttr;

    const pathMatch = window.location.pathname.match(/^\/([a-z]{2}(?:-[A-Z]{2})?)(?:\/|$)/);
    if (pathMatch && pathMatch[1]) return pathMatch[1];

    return 'en';
  }

  function initChat() {
    if (document.body.dataset.chatDelegateBound) return;

    document.body.dataset.chatDelegateBound = 'true';
    ensureStyle();

    document.body.addEventListener('click', async function (e) {
      const trigger = findTriggerFromEvent(e);
      if (!trigger) return;

      e.preventDefault();

      const locale = encodeURIComponent(detectStoreLocale());
      openChat('/apps/chat?redirect=1&locale=' + locale);
    }, true);

  }

  document.addEventListener('DOMContentLoaded', initChat);

  // fallback for Shopify themes (important)
  setInterval(initChat, 1000);

})();
</script>

{% schema %}
{
  "name": "FS Chat Loader",
  "target": "body",
  "settings": []
}
{% endschema %}